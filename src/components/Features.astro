        <div class="p-6 bg-gray-50 rounded-lg hover:shadow-lg transition-shadow">
          <h3 class="text-xl font-semibold text-primary mb-3">{feature.title}</h3>
          <p class="text-gray-600">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>