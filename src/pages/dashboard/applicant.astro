---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Dashboard Pelamar">
  <div class="min-h-screen bg-gray-100 p-8">
    <div class="max-w-4xl mx-auto">
      <div class="flex justify-between items-center mb-8">
        <h1 class="text-2xl font-bold">Dashboard Pelamar</h1>
        <button id="logoutBtn" class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600">Logout</button>
      </div>

      <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
        <p class="text-lg mb-4">Siap untuk tantangan baru? Lamar pekerjaan impian Anda sekarang.</p>
        <a href="/apply" class="inline-block bg-primary text-white px-6 py-3 rounded-lg hover:bg-primary-dark">
          Lamar Pekerjaan Baru →
        </a>
      </div>

      <div class="bg-white rounded-lg shadow-lg p-6">
        <h2 class="text-xl font-semibold mb-4">Riwayat & Status Lamaran</h2>
        <table class="w-full">
          <thead>
            <tr class="bg-gray-50">
              <th class="px-4 py-2 text-left">Posisi</th>
              <th class="px-4 py-2 text-left">Tanggal</th>
              <th class="px-4 py-2 text-left">Status</th>
            </tr>
          </thead>
          <tbody id="applicationsList">
            <!-- Data will be populated by JavaScript -->
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Check authentication
  if (!sessionStorage.getItem('loggedInUserEmail')) {
    window.location.href = '/login/applicant';
  }

  // Handle logout
  document.getElementById('logoutBtn')?.addEventListener('click', () => {
    sessionStorage.removeItem('loggedInUserEmail');
    window.location.href = '/login/applicant';
  });
</script>