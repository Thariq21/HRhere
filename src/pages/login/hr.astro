---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Login HR">
  <div class="min-h-screen bg-gray-100 flex items-center justify-center px-4">
    <div class="bg-white p-8 rounded-lg shadow-lg max-w-md w-full">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-primary">HRhere.id</h2>
        <p class="text-gray-600">Login Tim HR / Perusahaan</p>
      </div>
      <form id="loginHRForm" class="space-y-6">
        <div>
          <label for="emailHR" class="block text-sm font-medium text-gray-700 mb-1">Email Perusahaan</label>
          <input type="email" id="emailHR" name="emailHR" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" required>
        </div>
        <div>
          <label for="passwordHR" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
          <input type="password" id="passwordHR" name="passwordHR" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" required>
        </div>
        <button type="submit" class="w-full bg-primary text-white py-2 rounded-lg hover:bg-primary-dark transition-colors">Login</button>
      </form>
      <div class="mt-6 text-center">
        <p class="text-sm text-gray-600">Belum punya akun? <a href="/signup/hr" class="text-primary hover:underline">Daftar di sini</a></p>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.getElementById('loginHRForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('emailHR') as HTMLInputElement).value;
    const password = (document.getElementById('passwordHR') as HTMLInputElement).value;
    
    // Simulate login (replace with actual authentication)
    sessionStorage.setItem('loggedInHREmail', email);
    window.location.href = '/dashboard/hr';
  });
</script>